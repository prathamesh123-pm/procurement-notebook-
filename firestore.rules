rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ProcurePal Security Rules
     * 
     * Core Philosophy:
     * This ruleset implements a hybrid security model designed for milk procurement operations. 
     * It combines strict user-ownership for personal work data with a role-based access model 
     * for shared organizational resources.
     * 
     * Data Structure:
     * - Shared resources (Vehicles, Suppliers, Routes) are located in top-level collections.
     * - User-specific operational data (Tasks, Visit Reports, Daily Work Reports) are nested 
     *   within user subcollections at /users/{userId}/...
     * - Authorization status is determined by the presence of a document in the 
     *   /roles_teamMembers collection.
     * 
     * Key Security Decisions:
     * - Ownership Enforcement: All data under a /users/{userId} path is strictly restricted 
     *   to the authenticated user matching that ID.
     * - Denormalization for Authorization: Critical ID fields (like assignedToUserId) are 
     *   enforced within document bodies to ensure relational integrity and allow for 
     *   efficient, path-based listing without complex filters.
     * - Shared Access: Only users validated as "Team Members" (via the roles_teamMembers 
     *   collection) can view or modify global procurement resources.
     * - Prototyping Flexibility: Rules focus on authorization and relational integrity rather 
     *   than strict schema validation of content fields, allowing for rapid iteration.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the document exists and the user is the owner. Used for updates/deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Verifies if the authenticated user is a registered team member. */
    function isTeamMember() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_teamMembers/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents.
     * @path /users/{userId}
     * @allow (get) If signed in as the user. (create) If setting own profile.
     * @deny (list) Prevent broad user discovery.
     * @principle Ownership: Users manage their own profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for tasks assigned to specific users.
       * @path /users/{userId}/tasks/{taskId}
       * @allow (list) User listing their own tasks. (create) User creating a task for themselves.
       * @deny (create) Mismatched assignedToUserId and path userId.
       * @principle Relational Integrity: Enforces that the task's internal link matches its path.
       */
      match /tasks/{taskId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.assignedToUserId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.assignedToUserId == resource.data.assignedToUserId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for visit reports created by users.
       * @path /users/{userId}/visitReports/{visitReportId}
       * @allow (create) User logging a visit report for their own ID.
       * @deny (update) Attempting to change the visitedByUserId field.
       * @principle Ownership: Users own and manage their specific visit observations.
       */
      match /visitReports/{visitReportId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.visitedByUserId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.visitedByUserId == resource.data.visitedByUserId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for daily work summaries generated by users.
       * @path /users/{userId}/dailyWorkReports/{dailyWorkReportId}
       * @allow (get) User viewing their own daily report.
       * @deny (create) Mismatched generatedByUserId.
       * @principle Authorization Independence: Self-contained ownership validation.
       */
      match /dailyWorkReports/{dailyWorkReportId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.generatedByUserId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.generatedByUserId == resource.data.generatedByUserId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for defining application team members.
     * @path /roles_teamMembers/{uid}
     * @allow (get) User checking their own team status.
     * @deny (write) Prevent users from self-promoting to team member status.
     * @principle Explicit Roles: Membership is checked via document existence.
     */
    match /roles_teamMembers/{uid} {
      allow get: if isOwner(uid);
      allow list: if false;
      allow create, update, delete: if false; // Role management happens via Admin/Cloud Functions.
    }

    /**
     * @description Rules for shared vehicle resources.
     * @path /vehicles/{vehicleId}
     * @allow (list) Any authenticated team member.
     * @deny (read) Any user not in the roles_teamMembers collection.
     * @principle Shared Access: Organizational resources are shared among team members.
     */
    match /vehicles/{vehicleId} {
      allow get, list: if isTeamMember();
      allow create, update: if isTeamMember();
      allow delete: if isTeamMember() && resource != null;
    }

    /**
     * @description Rules for shared milk supplier records.
     * @path /suppliers/{supplierId}
     * @allow (update) Team member updating supplier notes or quantity.
     * @deny (get) Anonymous or non-team users.
     * @principle DBAC: Database-level access control based on team role.
     */
    match /suppliers/{supplierId} {
      allow get, list: if isTeamMember();
      allow create, update: if isTeamMember();
      allow delete: if isTeamMember() && resource != null;
    }

    /**
     * @description Rules for shared procurement routes.
     * @path /routes/{routeId}
     * @allow (list) Team member viewing the route map.
     * @deny (create) Mismatched route vehicle assignment (logic handled in app, checked for role here).
     * @principle Shared Resource: Routes are managed by the procurement team.
     */
    match /routes/{routeId} {
      allow get, list: if isTeamMember();
      allow create, update: if isTeamMember();
      allow delete: if isTeamMember() && resource != null;
    }

  }
}